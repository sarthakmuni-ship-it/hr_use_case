# ==========================
# Application
# ==========================
APP_NAME=HR Background Verification API
APP_VERSION=1.0.0
APP_DESCRIPTION=AI Powered HR Background Verification System

# ==========================
# Database
# ==========================
DATABASE_URL=mysql+aiomysql://USER:PASSWORD@localhost:3306/hr_background_verification_db
EMPLOYEE_DATA_PATH=app/data/employees.json
EMAIL_FILE_PATH=app/data/emails.json

# ==========================
# AI Model
# ==========================
LLM_PROVIDER=llama
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=your_api_key
LLM_MODEL=your_model_name
LLAMA_BASE_URL=https://your-llama-host.example.com/ollama/api
LLAMA_MODEL=llama3.1:8b
LLAMA_VERIFY_SSL=false
LLAMA_USERNAME=*****
LLAMA_PASSWORD=*****
# ==========================
# Mail Configuration
# ==========================
MAIL_PROVIDER=GMAIL_IMAP
MAIL_POLL_INTERVAL=5
EMAIL_SOURCE=gmail
ENABLE_BACKGROUND_INGESTION=false
ENABLE_BACKGROUND_PROCESSING=false

# ==========================
# Web
# ==========================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==========================
# Gmail IMAP
# ==========================
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_USERNAME=
GMAIL_IMAP_PASSWORD=
GMAIL_IMAP_MAILBOX=INBOX
GMAIL_IMAP_SEARCH_CRITERIA=UNSEEN
GMAIL_ATTACHMENT_DIR=app/data/attachments
SMTP_USERNAME=opsagent-wildu@jadeglobal.com
SMTP_PASSWORD=vjsa edpq ltfk pljn

# ==========================
# Logging
# ==========================
LOG_LEVEL=INFO

# ==========================
# JWT Configuration
# ==========================
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_TOKEN_URL=/api/auth/login
